from collections import deque

class Queue:
    def __init__(self):
        self.queue = deque()

    # Enqueue: Add to the rear
    def enqueue(self, item):
        self.queue.append(item)

    # Dequeue: Remove from the front
    def dequeue(self):
        if not self.is_empty():
            return self.queue.popleft() # Removes from the far left (front)
        raise IndexError("Dequeue from empty queue")

    def peek(self):
        if not self.is_empty():
            return self.queue[0]
        return None

    def is_empty(self):
        return len(self.queue) == 0

    def display(self):
        print("Front ->", list(self.queue), "<- Rear")

# --- Execution ---
q = Queue()
q.enqueue("Alice")
q.enqueue("Bob")
q.enqueue("Charlie")
print("Queue after enqueues:")
q.display()  # Output: Front -> ['Alice', 'Bob', 'Charlie'] <- Rear

print("\nServed (Dequeued):", q.dequeue()) # Output: Alice
print("Queue after dequeue:")
q.display()  # Output: Front -> ['Bob', 'Charlie'] <- Rear